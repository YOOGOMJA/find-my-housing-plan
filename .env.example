# LH 공고 알림 환경변수
#
# 타입 가이드
# - string: 일반 문자열
# - number: 숫자(정수/실수)
# - url: 웹 주소
# - date(YYYY-MM-DD): 날짜 문자열
# - csv(code): 코드값을 쉼표(,)로 나열
# - enum(...): 허용된 값 중 하나만 입력
#
# 참고
# - 실제 운영 시 예시값이 아닌 본인 값으로 교체하세요.
# - USER_REGIONS에 00을 넣으면 전국 공고를 허용합니다.

# [API 연동 키]
# PUBLIC_DATA_API_KEY
# 타입: string
# 설명: LH 공공데이터포털 API 인증키
# 예시: your-public-data-api-key
PUBLIC_DATA_API_KEY=your-public-data-api-key

# ANTHROPIC_API_KEY
# 타입: string
# 설명: Claude 파싱용 Anthropic API 키
# 예시: sk-ant-api03-xxxx
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# SLACK_WEBHOOK_URL
# 타입: url
# 설명: Slack Incoming Webhook URL
# 예시: https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# [사용자 기본 정보]
# USER_AGE
# 타입: number
# 설명: 사용자 만 나이
# 예시: 35
USER_AGE=35

# USER_MARITAL_STATUS
# 타입: enum(single|married|newlywed)
# 설명: 혼인 상태
# 예시: single
USER_MARITAL_STATUS=single

# USER_HOUSEHOLD_SIZE
# 타입: number
# 설명: 세대원 수
# 예시: 1
USER_HOUSEHOLD_SIZE=1

# USER_CURRENT_REGION
# 타입: string(code)
# 설명: 현재 거주 지역 코드 (예: 서울 11)
# 예시: 11
USER_CURRENT_REGION=11

# USER_NO_HOME_YEARS
# 타입: number
# 설명: 무주택 기간(년)
# 예시: 4
USER_NO_HOME_YEARS=4

# [자격 판단 입력값]
# USER_INCOME
# 타입: number
# 설명: 월 소득(만원 단위)
# 예시: 300
USER_INCOME=300

# USER_ASSET
# 타입: number
# 설명: 총 자산(만원 단위)
# 예시: 30000
USER_ASSET=30000

# USER_CAR_ASSET
# 타입: number
# 설명: 자동차 자산가액(만원 단위)
# 예시: 0
USER_CAR_ASSET=0

# USER_SUBSCRIPTION_DATE
# 타입: date(YYYY-MM-DD)
# 설명: 청약통장 가입일
# 예시: 2020-01-01
USER_SUBSCRIPTION_DATE=2020-01-01

# USER_SUBSCRIPTION_COUNT
# 타입: number
# 설명: 청약통장 납입 횟수
# 예시: 24
USER_SUBSCRIPTION_COUNT=24

# USER_SUBSCRIPTION_AMOUNT
# 타입: number
# 설명: 청약통장 납입 총액(만원 단위)
# 예시: 480
USER_SUBSCRIPTION_AMOUNT=480

# [주택 선호 조건]
# USER_REGIONS
# 타입: csv(code)
# 설명: 관심 지역 코드 목록 (쉼표 구분, 전국 포함 시 00)
# 예시: 11,41
USER_REGIONS=11,41

# USER_MIN_AREA
# 타입: number
# 설명: 최소 희망 전용면적(㎡)
# 예시: 20
USER_MIN_AREA=20

# USER_MAX_AREA
# 타입: number
# 설명: 최대 희망 전용면적(㎡)
# 예시: 60
USER_MAX_AREA=60

# USER_MIN_BUILD_YEAR
# 타입: number
# 설명: 최소 희망 준공연도
# 예시: 0
USER_MIN_BUILD_YEAR=0

# USER_HOUSING_TYPES
# 타입: csv(code)
# 설명: 관심 주택/공고 유형 코드 목록 (쉼표 구분)
# 예시: 06,13
USER_HOUSING_TYPES=06,13

# USER_DISTRICTS
# 타입: csv(string)
# 설명: 선호 구 단위 지역 (쉼표 구분, 소프트 필터 — 미입력 시 필터 안 함)
# 예시: 송파구,관악구
USER_DISTRICTS=

# USER_MAX_DEPOSIT
# 타입: number
# 설명: 보증금 최대 (만원, 0이면 필터 안 함)
# 예시: 15000
USER_MAX_DEPOSIT=0

# USER_MAX_RENT
# 타입: number
# 설명: 월임대료 최대 (만원, 0이면 필터 안 함)
# 예시: 50
USER_MAX_RENT=0

# USER_APPLICANT_GROUP
# 타입: enum(general|youth|newlywed|newborn|multiChild)
# 설명: 특별공급 신청 트랙
# 예시: youth
USER_APPLICANT_GROUP=general

# [재처리 모드]
# REPROCESS_ENABLED
# 타입: enum(true|false)
# 설명: true면 기처리 상태를 무시하고 최근 기간 공고를 재처리
# 예시: false
REPROCESS_ENABLED=false

# REPROCESS_DRY_RUN
# 타입: enum(true|false)
# 설명: true면 Slack 전송/상태 저장 없이 건수만 점검
# 예시: true
REPROCESS_DRY_RUN=false

# REPROCESS_LOOKBACK_MONTHS
# 타입: number
# 설명: 재처리 대상 조회 기간(개월)
# 예시: 6
REPROCESS_LOOKBACK_MONTHS=6

# REPROCESS_MAX_NOTIFICATIONS
# 타입: number
# 설명: 한 번 실행에서 Slack 전송 최대 건수(조건충족+수동확인 합산)
# 예시: 50
REPROCESS_MAX_NOTIFICATIONS=50
